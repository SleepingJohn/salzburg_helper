{
  "expo": {
    "name": "Salzburg Citizen Report",
    "slug": "salzburg-citizen-report",
    "scheme": "salzburgreport",
    "platforms": ["ios", "android", "web"],
    "sdkVersion": "54.0.0",
    "version": "1.0.0",
    "icon": "./assets/images/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f4ee"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f7f4ee"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Salzburg Citizen Report to choose photos for issue reports.",
          "cameraPermission": "Allow Salzburg Citizen Report to take photos for issue reports."
        }
      ],
      "expo-document-picker"
    ],
    "assetBundlePatterns": ["**/*"]
  }
}
